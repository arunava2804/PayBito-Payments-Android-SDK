<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/dark_bg_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:strokeColor="#1AFFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <!-- Success Icon Container -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_step_circle_current"
                    android:backgroundTint="#1A22C97A">

                    <ImageView
                        android:id="@+id/ivStatusIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/checkbox_on_background"
                        app:tint="@color/success_green" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/ibmplexsans_medium"
                    android:letterSpacing="0.2"
                    android:text="PAYMENT CONFIRMED"
                    android:textColor="@color/success_green"
                    android:textSize="@dimen/_10ssp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStatusTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/ibmplexsans_semi_bold"
                    android:gravity="center"
                    android:text="Order Placed\nSuccessfully!"
                    android:textColor="@color/dark_text_primary"
                    android:textSize="@dimen/_22ssp" />

                <TextView
                    android:id="@+id/tvStatusMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/ibmplexsans_regular"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:text="Your payment has been processed and your order is confirmed. A confirmation will be sent shortly."
                    android:textColor="@color/dark_text_secondary"
                    android:textSize="@dimen/_12ssp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="32dp"
                    android:background="#1AFFFFFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackHome"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="@color/success_green"
                    android:fontFamily="@font/ibmplexsans_medium"
                    android:text="Continue Shopping"
                    android:textAllCaps="false"
                    android:textColor="#0A0E17"
                    android:textSize="@dimen/_12ssp"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_search"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconTint="#0A0E17" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_shopping_cart"
                        app:tint="@color/dark_text_dim" />

                    <TextView
                        android:id="@+id/tvSecuredBy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="@font/ibmplexsans_regular"
                        android:text="Secured by Broker"
                        android:textColor="@color/dark_text_dim"
                        android:textSize="@dimen/_9ssp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
