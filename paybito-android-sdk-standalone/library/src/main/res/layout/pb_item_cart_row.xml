<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/_10sdp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivItemImage"
        android:layout_width="@dimen/_44sdp"
        android:layout_height="@dimen/_44sdp"
        android:scaleType="centerCrop"
        android:background="@color/pb_dark_surface"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.LargeComponent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ibmplexsans_semi_bold"
            android:textColor="@color/pb_text_primary"
            android:textSize="@dimen/_11ssp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_4sdp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnItemMinus"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:background="@drawable/bg_icon_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/pb_text_secondary"
                android:textSize="@dimen/_12ssp"
                android:fontFamily="@font/ibmplexsans_medium" />

            <TextView
                android:id="@+id/tvItemQty"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/pb_text_primary"
                android:textSize="@dimen/_10ssp"
                android:fontFamily="@font/ibmplexsans_semi_bold" />

            <TextView
                android:id="@+id/btnItemPlus"
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:background="@drawable/bg_icon_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/pb_text_secondary"
                android:textSize="@dimen/_12ssp"
                android:fontFamily="@font/ibmplexsans_medium" />

            <TextView
                android:id="@+id/tvItemUnitPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_8sdp"
                android:fontFamily="@font/ibmplexsans_regular"
                android:text="x $0.00"
                android:textColor="@color/pb_text_secondary"
                android:textSize="@dimen/_9ssp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvItemSubtotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/ibmplexsans_semi_bold"
        android:text="$0.00"
        android:textColor="@color/pb_accent"
        android:textSize="@dimen/_11ssp" />

</LinearLayout>