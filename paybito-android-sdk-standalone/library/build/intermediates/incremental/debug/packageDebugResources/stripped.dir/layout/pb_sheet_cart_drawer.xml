<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/_14sdp"
    android:paddingTop="@dimen/_8sdp"
    android:paddingBottom="@dimen/_14sdp">

    <View
        android:layout_width="@dimen/_30sdp"
        android:layout_height="@dimen/_3sdp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_drag_handle" />

    <TextView
        android:id="@+id/tvCartTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_12sdp"
        android:fontFamily="@font/ibmplexsans_semi_bold"
        android:text="Your Cart"
        android:textColor="@color/pb_text_primary"
        android:textSize="@dimen/_13ssp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="@dimen/_8sdp"
        android:background="#1AFFFFFF" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCartItems"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_300sdp"
        android:layout_marginTop="@dimen/_8sdp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="@dimen/_8sdp"
        android:background="#1AFFFFFF" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_12sdp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ibmplexsans_regular"
            android:text="Total Amount"
            android:textColor="@color/pb_text_secondary"
            android:textSize="@dimen/_10ssp" />

        <TextView
            android:id="@+id/tvDrawerTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:fontFamily="@font/ibmplexsans_semi_bold"
            android:text="$0.00"
            android:textColor="@color/pb_accent"
            android:textSize="@dimen/_14ssp" />
    </RelativeLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCheckout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_36sdp"
        android:layout_marginTop="@dimen/_16sdp"
        android:backgroundTint="@color/pb_accent"
        android:fontFamily="@font/ibmplexsans_medium"
        android:text="Proceed to Checkout"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/_11ssp"
        app:cornerRadius="@dimen/_12sdp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

    <TextView
        android:id="@+id/tvSecuredBy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_12sdp"
        android:gravity="center"
        android:text="🔒 Secured by PayBito"
        android:textColor="#40FFFFFF"
        android:textSize="@dimen/_9ssp"
        android:fontFamily="@font/ibmplexsans_regular" />

</LinearLayout>